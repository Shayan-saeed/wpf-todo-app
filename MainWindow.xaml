<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPFDemo"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="WPFDemo.MainWindow"
        Title="MainWindow"
        Height="520" 
        Width="820" 
        Background="#F5F6F8"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="LightGray" />
            <Setter Property="Foreground" Value="DarkSlateGray" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Width" Value="75" />
            <Setter Property="Margin" Value="10,20,0,0" />
            <Setter Property="BorderBrush" Value="LightGray" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="40">
        
        <Border Background="White" CornerRadius="14" Padding="24">
            <StackPanel>
                <TextBlock 
                    Text="My Tasks"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Margin="0,0,0,20"
                    Foreground="#1F2937"/>

                <Border
                    Background="#F3F4F6"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,0,20">
                    <DockPanel>
                        <TextBox
                            Text="{Binding NewItemText, Mode=TwoWay}" 
                            BorderThickness="0"
                            Background="Transparent"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            DockPanel.Dock="Left"
                            Width="520" />

                        <Button Content="+"
                            Width="40"
                            Height="40"
                            FontSize="20"
                            Command="{Binding AddItemCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />       
                    </DockPanel>
                </Border>
                
                <ListBox 
                    ItemsSource="{Binding TasksView}"
                    BorderThickness="0" 
                    Background="Transparent"
                    Margin="0,0,0,20">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Background="#F9FAFB"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,10">
                                
                                <DockPanel>
                                    <CheckBox
                                        IsChecked="{Binding IsCompleted}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0"/>

                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="14"
                                        VerticalAlignment="Center"
                                        Foreground="#111827"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <DockPanel>

                    <!-- Delete Completed -->
                    <Button
                        Content="Delete completed"
                        Command="{Binding DeleteCompletedCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#EF4444"
                        Cursor="Hand"
                        DockPanel.Dock="Left"/>

                    <!-- Filters -->
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                        <Button
                            Content="All"
                            Command="{Binding ShowAllCommand}"
                            Style="{StaticResource FilterButtonStyle}"/>

                        <Button
                            Content="Active"
                            Command="{Binding ShowActiveCommand}"
                            Style="{StaticResource FilterButtonStyle}"/>

                        <Button
                            Content="Completed"
                            Command="{Binding ShowCompletedCommand}"
                            Style="{StaticResource FilterButtonStyle}"/>

                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>
        

    </Grid>
</Window>
